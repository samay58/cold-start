{
  "name": "cold-start",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @cold-start/web",
    "dev:extension": "npm run dev -w @cold-start/extension",
    "dev:inngest": "bash scripts/dev-inngest.sh",
    "dev:full": "node scripts/dev-full.mjs",
    "dev:fresh": "rm -rf apps/web/.next apps/web/.cold-start && npm run dev:full",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && node --test eval/*.test.mjs eval/**/*.test.mjs",
    "lint": "eslint .",
    "check": "npm run lint -- --max-warnings=0 && npm run typecheck && npm run test && npm run build && npm run build:firefox -w @cold-start/extension && npx --yes web-ext@10.5.0 lint --source-dir apps/extension/dist-firefox --self-hosted && npm run eval:golden -- --dry-run --limit 12 && npm run knip && npm run secrets:check && npm run audit:deps",
    "knip": "knip",
    "secrets:check": "node scripts/secrets-check.mjs",
    "audit:deps": "node scripts/audit-deps.mjs",
    "vercel:login": "vercel login",
    "db:generate": "npm run db:generate -w @cold-start/db",
    "db:migrate": "npm run db:migrate -w @cold-start/db",
    "db:migrate:production": "node scripts/migrate-production.mjs",
    "trace:generation": "tsx scripts/trace-generation.ts",
    "measure:first-usable": "tsx scripts/measure-first-usable.ts",
    "measure:analysis-latency": "tsx scripts/measure-analysis-latency.ts",
    "study:synthesis-gate": "tsx scripts/study-synthesis-gate.ts",
    "measure:contact-yield": "tsx scripts/measure-contact-yield.ts",
    "optimize:generation": "tsx scripts/optimize-generation.ts",
    "evo:generation-benchmark": "tsx scripts/evo-generation-benchmark.ts",
    "evo:generation-gate": "tsx scripts/evo-generation-benchmark.ts --gate",
    "evo:ux-benchmark": "tsx scripts/evo-ux-benchmark.ts",
    "evo:ux-gate": "tsx scripts/evo-ux-benchmark.ts --gate",
    "qa:generation": "tsx scripts/qa-generation-suite.ts",
    "repair:sections": "tsx scripts/repair-research-sections.ts",
    "repair:signal-clusters": "tsx scripts/repair-signal-clusters.ts",
    "repair:stuck-runs": "tsx scripts/repair-stuck-generation-runs.ts",
    "verify:cache-ttl": "tsx scripts/verify-cache-ttl.ts",
    "wallet:status": "tsx scripts/wallet-status.ts",
    "eval:seed": "node -e \"const data=require('./eval/golden-companies.seed.json'); console.log(data.length)\"",
    "eval:golden": "node eval/run-golden.mjs",
    "eval:providers:bundles": "tsx eval/provider-matrix/build-bundles.ts",
    "eval:providers:matrix": "tsx eval/provider-matrix/run-matrix.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@eslint/js": "^9.39.4",
    "@next/env": "^15.5.15",
    "@next/eslint-plugin-next": "^15.5.18",
    "@types/node": "^22.15.0",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "inngest-cli": "^1.37.0",
    "knip": "^6.14.2",
    "next": "^15.5.18",
    "pg": "^8.20.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.59.4",
    "vercel": "^54.14.5",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "@vercel/blob": {
      "undici": "6.27.0"
    },
    "@vercel/node": {
      "path-to-regexp": "6.3.0",
      "undici": "5.28.5"
    },
    "@vercel/python-analysis": {
      "minimatch": "^10.2.5",
      "smol-toml": "^1.6.1",
      "js-yaml": "^4.3.0"
    },
    "minimatch@3.1.5": {
      "brace-expansion": "^1.1.16"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "^5.0.7"
    },
    "axios": "^1.18.1",
    "js-yaml": "^4.3.0",
    "postcss": "^8.5.15",
    "ws": "^8.21.0"
  },
  "knip": {
    "ignoreDependencies": [
      "inngest-cli"
    ],
    "ignore": [
      "apps/extension/public/theme-boot.js"
    ]
  }
}
