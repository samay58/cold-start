{
  "name": "cold-start",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @cold-start/web",
    "dev:extension": "npm run dev -w @cold-start/extension",
    "dev:inngest": "bash scripts/dev-inngest.sh",
    "dev:full": "node scripts/dev-full.mjs",
    "dev:fresh": "rm -rf apps/web/.next apps/web/.cold-start && npm run dev:full",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && node --test eval/*.test.mjs",
    "lint": "eslint .",
    "check": "npm run lint -- --max-warnings=0 && npm run typecheck && npm run test && npm run build && npm run eval:golden -- --dry-run --limit 12 && npm run knip && npm run secrets:check && npm run audit:deps",
    "knip": "knip",
    "secrets:check": "node scripts/secrets-check.mjs",
    "audit:deps": "node scripts/audit-deps.mjs",
    "vercel:login": "vercel login",
    "db:generate": "npm run db:generate -w @cold-start/db",
    "db:migrate": "npm run db:migrate -w @cold-start/db",
    "db:migrate:production": "node scripts/migrate-production.mjs",
    "trace:generation": "tsx scripts/trace-generation.ts",
    "optimize:generation": "tsx scripts/optimize-generation.ts",
    "qa:generation": "tsx scripts/qa-generation-suite.ts",
    "repair:sections": "tsx scripts/repair-research-sections.ts",
    "verify:cache-ttl": "tsx scripts/verify-cache-ttl.ts",
    "wallet:status": "tsx scripts/wallet-status.ts",
    "eval:seed": "node -e \"const data=require('./eval/golden-companies.seed.json'); console.log(data.length)\"",
    "eval:golden": "node eval/run-golden.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@eslint/js": "^9.39.4",
    "@next/env": "^15.5.15",
    "@types/node": "^22.15.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "inngest-cli": "^1.19.1",
    "knip": "^6.14.2",
    "next": "^15.5.18",
    "pg": "^8.20.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.59.4",
    "vercel": "^54.2.0",
    "vitest": "^3.2.0"
  },
  "knip": {
    "ignoreDependencies": [
      "inngest-cli"
    ]
  }
}
