{
  "name": "@cold-start/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "qa:extension:smoke": "npm run build && playwright test --config=playwright.smoke.config.ts --project=extension-smoke",
    "qa:extension:ui": "playwright test --project=sidepanel-ui",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cold-start/core": "file:../../packages/core",
    "@cold-start/ui": "file:../../packages/ui",
    "@crxjs/vite-plugin": "^2.0.0-beta.32",
    "@paper-design/shaders-react": "^0.0.76",
    "@vitejs/plugin-react": "^5.0.0",
    "framer-motion": "^12.38.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.330",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
