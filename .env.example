DATABASE_URL=postgres://coldstart:local@127.0.0.1:55432/coldstart
ANTHROPIC_API_KEY=sk-ant-example
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_EXTRACT_MODEL=
ANTHROPIC_BLOCK_MODEL=
ANTHROPIC_SYNTHESIS_MODEL=
ANTHROPIC_VERIFIER_MODEL=
ANTHROPIC_RESEARCH_PLAN_MODEL=
# Per-stage provider routing. Accepts provider-prefixed model strings
# (e.g. deepseek/deepseek-v4-flash); unprefixed strings are Anthropic models.
# Each falls back to its ANTHROPIC_* counterpart, then ANTHROPIC_MODEL.
LLM_EXTRACT_MODEL=
LLM_BLOCK_MODEL=
LLM_VERIFIER_MODEL=
LLM_SYNTHESIS_MODEL=
LLM_RESEARCH_SECTION_MODEL=
LLM_RESEARCH_PLAN_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
LLM_OPENAI_COMPAT_TIMEOUT_MS=
X402_PRIVATE_KEY=
STABLEENRICH_BASE_URL=https://stableenrich.dev
STABLEENRICH_EXA_SEARCH_URL=
STABLEENRICH_EXA_SIMILAR_URL=
STABLEENRICH_FIRECRAWL_URL=
STABLEENRICH_ORG_ENRICH_URL=
# Analysis-mode source re-fetch policy on the reuse-existing-extraction branch: full | targeted |
# skip-fresh. Default full (today's unconditional 13-probe fetch); nothing changes until promoted.
ANALYSIS_SOURCE_REFRESH=full
DIRECT_EXA_API_KEY=
DIRECT_EXA_BASE_URL=
EXA_WEBSETS_CONTACTS_ENABLED=false
EMAIL_PATTERN_FALLBACK_ENABLED=true
EXA_WEBSETS_API_KEY=
EXA_WEBSETS_BASE_URL=
# Durable websets polling window (attempts x seconds; defaults 6 x 20s) and the per-credit USD
# rate used for cost telemetry (defaults to the Starter plan rate).
WEBSETS_POLL_ATTEMPTS=
WEBSETS_POLL_INTERVAL_SECONDS=
EXA_WEBSETS_CREDIT_USD=
DIRECT_FIRECRAWL_API_KEY=
DIRECT_PDL_API_KEY=
FAST_BASICS_ENABLED=true
PUBLIC_GENERATION_ENABLED=false
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000
VITE_COLD_START_API_ORIGIN=http://localhost:3000
CHROME_EXTENSION_ID=local-dev
ALLOWED_EXTENSION_ORIGINS=chrome-extension://*,http://localhost:5173
EXTENSION_API_TOKEN=local-extension-token
INNGEST_EVENT_KEY=local-event-key
INNGEST_SIGNING_KEY=local-signing-key
